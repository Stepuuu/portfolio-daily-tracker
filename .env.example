# API Keys (at least one is required)
ANTHROPIC_API_KEY=your_claude_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Optional: DeepSeek or other OpenAI-compatible API
# DEEPSEEK_API_KEY=your_deepseek_key_here

# Optional: Proxy for Yahoo Finance (if blocked in your region)
# HTTP_PROXY=http://127.0.0.1:7890

# Optional: Feishu chat ID for daily push
# FEISHU_CHAT_ID=your_chat_id_here

# Optional: Portfolio data directory (default: ./engine/portfolio)
# PORTFOLIO_DIR=/path/to/portfolio
